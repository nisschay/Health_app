# Backend API environment example
# Copy to backend_api/.env for local runs or map these in production.

# Required for Gemini-powered analysis/chat/export
GEMINI_API_KEY=your_gemini_api_key

# Set true in production when Firebase auth is enabled
API_REQUIRE_AUTH=false

# Firebase Admin SDK credentials (JSON file path on backend host)
FIREBASE_CREDENTIALS_PATH=/absolute/path/to/serviceAccountKey.json
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLOCK_SKEW_SECONDS=60

# Comma-separated list of frontend origins allowed to call this API
API_CORS_ORIGINS=http://localhost:3000

# PostgreSQL connection string
DATABASE_URL=postgresql://medical_user:medical_pass@localhost:5432/medical_project
